# .env.local
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API

# Public anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic API ───────────────────────────────────────────────────────────
# Used for AI invoice extraction (server-side only)
# Create at: https://console.anthropic.com/
# Note: The fetch in extractor.ts uses the standard /v1/messages endpoint.
# The API key is passed via the Authorization header automatically by the
# Anthropic Claude.ai platform. For standalone deployment, you MUST set this.
ANTHROPIC_API_KEY=sk-ant-...

# ── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
